#!/usr/bin/env bash
set -euo pipefail

# Usage: get-secret <name>
# Example: get-secret openai_api_key
# Decrypts: $HOME/lyra-secrets/<name>.gpg  to stdout

NAME="${1:-}"
if [[ -z "$NAME" ]]; then
  echo "Usage: $(basename "$0") <secret_name>" >&2
  exit 2
fi

# Only allow safe names: letters, digits, underscore, dash, dot
if [[ ! "$NAME" =~ ^[a-zA-Z0-9_.-]+$ ]]; then
  echo "Invalid secret name." >&2
  exit 2
fi

SECRETS_DIR="$HOME/lyra-secrets"
FILE="$SECRETS_DIR/${NAME}.gpg"

# Hard fail if missing
if [[ ! -f "$FILE" ]]; then
  echo "Secret not found: $FILE" >&2
  exit 3
fi

# Permissions sanity check (optional but recommended)
# Refuse if secrets dir is not private
DIR_MODE="$(stat -c '%a' "$SECRETS_DIR" 2>/dev/null || echo "")"
if [[ "$DIR_MODE" != "700" ]]; then
  echo "Refusing: secrets dir permissions should be 700 (current: $DIR_MODE)" >&2
  exit 4
fi

# Refuse if secret file is too permissive
FILE_MODE="$(stat -c '%a' "$FILE" 2>/dev/null || echo "")"
if [[ "$FILE_MODE" != "600" ]]; then
  echo "Refusing: secret file permissions should be 600 (current: $FILE_MODE)" >&2
  exit 5
fi

# Decrypt to stdout (quiet, no extra noise)
exec gpg --quiet --decrypt "$FILE"
