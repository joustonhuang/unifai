#!/usr/bin/env bash
set -euo pipefail

# Usage: get-secret <name>
# Example: get-secret openai_api_key
# Decrypts: $HOME/lyra-secrets/<name>.gpg  to stdout


# ---- Fuse gate: block cloud keys during fuse window ----
FUSE_STATE_FILE="/var/lib/little7/fuse_state.json"
NOW_EPOCH="$(date +%s)"

if [ -f "$FUSE_STATE_FILE" ]; then
  # Parse minimal fields via python (avoid jq dependency)
  FUSE_STATE="$(python3 - <<'PY'
import json, sys
p="/var/lib/little7/fuse_state.json"
try:
    d=json.load(open(p,"r",encoding="utf-8"))
except Exception:
    print("OPEN"); sys.exit(0)

state=str(d.get("state","OPEN")).upper()
scope=str(d.get("scope","cloud_all"))
until=int(d.get("until_epoch",0) or 0)
reason=str(d.get("reason_code",""))
note=str(d.get("note",""))
print(f"{state}\t{scope}\t{until}\t{reason}\t{note}")
PY
  )"

  # Expected: STATE \t SCOPE \t UNTIL \t REASON \t NOTE
  STATE="$(printf "%s" "$FUSE_STATE" | awk -F'\t' '{print $1}')"
  SCOPE="$(printf "%s" "$FUSE_STATE" | awk -F'\t' '{print $2}')"
  UNTIL="$(printf "%s" "$FUSE_STATE" | awk -F'\t' '{print $3}')"
  REASON="$(printf "%s" "$FUSE_STATE" | awk -F'\t' '{print $4}')"
  NOTE="$(printf "%s" "$FUSE_STATE" | awk -F'\t' '{print $5}')"

  if [ "$STATE" = "TRIPPED" ] && [ "$NOW_EPOCH" -lt "${UNTIL:-0}" ]; then
    # MVP: block all cloud keys when scope=cloud_all
    # (Later: implement per-provider / per-agent scopes)
    if [ "$SCOPE" = "cloud_all" ]; then
      echo "FUSE_TRIPPED until=$UNTIL reason=$REASON note=$NOTE" >&2
      exit 75
    fi
  fi
fi
# ---- end Fuse gate ----

NAME="${1:-}"
if [[ -z "$NAME" ]]; then
  echo "Usage: $(basename "$0") <secret_name>" >&2
  exit 2
fi

# Only allow safe names: letters, digits, underscore, dash, dot
if [[ ! "$NAME" =~ ^[a-zA-Z0-9_.-]+$ ]]; then
  echo "Invalid secret name." >&2
  exit 2
fi

#SECRETS_DIR="$HOME/lyra-secrets"
SECRETS_DIR="/etc/little7/secrets"
FILE="$SECRETS_DIR/${NAME}.gpg"

# Hard fail if missing
if [[ ! -f "$FILE" ]]; then
  echo "Secret not found: $FILE" >&2
  exit 3
fi

# Permissions sanity check (recommended)
DIR_MODE="$(stat -c '%a' "$SECRETS_DIR" 2>/dev/null || echo "")"
DIR_OWNER="$(stat -c '%U:%G' "$SECRETS_DIR" 2>/dev/null || echo "")"
if [[ "$DIR_OWNER" != "root:root" ]]; then
  echo "Refusing: secrets dir must be owned by root:root (current: $DIR_OWNER)" >&2
  exit 4
fi
if [[ "$DIR_MODE" != "700" && "$DIR_MODE" != "750" ]]; then
  echo "Refusing: secrets dir permissions should be 700 or 750 (current: $DIR_MODE)" >&2
  exit 4
fi

FILE_MODE="$(stat -c '%a' "$FILE" 2>/dev/null || echo "")"
FILE_OWNER="$(stat -c '%U:%G' "$FILE" 2>/dev/null || echo "")"
if [[ "$FILE_OWNER" != "root:root" ]]; then
  echo "Refusing: secret file must be owned by root:root (current: $FILE_OWNER)" >&2
  exit 5
fi
if [[ "$FILE_MODE" != "600" && "$FILE_MODE" != "640" ]]; then
  echo "Refusing: secret file permissions should be 600 or 640 (current: $FILE_MODE)" >&2
  exit 5
fi
