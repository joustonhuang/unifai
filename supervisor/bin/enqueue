#!/usr/bin/env bash
set -euo pipefail

DB="$HOME/supervisor/data/supervisor.db"
SPEC="${1:-}"

if [[ -z "$SPEC" ]]; then
  echo "Usage: enqueue '{\"type\":\"tool\",\"cmd\":\"date\",\"args\":[]}'"
  exit 1
fi

sqlite3 "$DB" "INSERT INTO tasks(created_at,status,spec) VALUES(datetime('now'),'queued','$SPEC');"
echo "queued."
