# Repo secretvault structure
/lyra-supervisor/supervisor-secretvault/*
!/lyra-supervisor/supervisor-secretvault/README.md
!/lyra-supervisor/supervisor-secretvault/install.sh
!/lyra-supervisor/supervisor-secretvault/uninstall.sh
!/lyra-supervisor/supervisor-secretvault/secrets/
!/lyra-supervisor/supervisor-secretvault/grants/
!/lyra-supervisor/supervisor-secretvault/audit/
!/lyra-supervisor/supervisor-secretvault/config/
!/lyra-supervisor/supervisor-secretvault/tmp/
!/lyra-supervisor/supervisor-secretvault/secrets/.gitkeep
!/lyra-supervisor/supervisor-secretvault/grants/.gitkeep
!/lyra-supervisor/supervisor-secretvault/audit/.gitkeep
!/lyra-supervisor/supervisor-secretvault/config/.gitkeep
!/lyra-supervisor/supervisor-secretvault/tmp/.gitkeep

# =========================
# Local testing artifacts
# =========================
tmp/
!/lyra-supervisor/supervisor-secretvault/tmp/
!/lyra-supervisor/supervisor-secretvault/tmp/.gitkeep
.cache/

